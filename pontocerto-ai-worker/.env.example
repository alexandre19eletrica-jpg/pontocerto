# Copie para .env e preencha

# HTTP / seguranca local
WORKER_HTTP_PORT=37651
WORKER_HTTP_SECRET=defina_um_segredo_longo_aleatorio

# Identidade Firestore (mesmo UID da conta suprema que usa o agente)
WORKER_OWNER_UID=

# Firebase Admin — JSON da conta de servico com permissao Firestore (apenas na sua maquina; nunca commit)
FIREBASE_SERVICE_ACCOUNT_PATH=
# Studio (`studiopontocerto`): fila `engineering_agent_worker_jobs` neste projeto.
# Mono-repo ERP (`pontocerto-e1dab`): só se o worker for usado pelo agente da Web ERP.
FIRESTORE_PROJECT_ID=studiopontocerto

# Polling fila engineering_agent_worker_jobs (ms)
POLL_INTERVAL_MS=3500

# Execucao
COMMAND_TIMEOUT_MS=900000
MAX_STDOUT_CHARS=400000
MAX_STDERR_CHARS=120000

# Root opcional — todos os caminhos relativos HTTP ficam confinados aqui se definido
DEFAULT_PROJECT_ROOT=

# VS Code (opcional): pasta ou ficheiro a abrir
VSCODE_CLI=vscode

# Logs WebSocket (true/false)
WS_LOG_BROADCAST=true

# chokidar opcional — pastas separadas por ; (Windows)
WATCH_DIRS=
