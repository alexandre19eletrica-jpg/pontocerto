**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
.gradle-local/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Artefacto Android copiado para a raiz (nunca versionar)
/app-release.aab

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
android/.gradle-user/
android/.gradle/
android/.kotlin/
android/key.properties
android/app/upload-keystore.jks
.env.openai.local

# Node / Firebase Functions
node_modules/
functions/node_modules/

# Segredos locais (não commitar)
functions/.env
functions/.env.*

# Cópia local de backup (repositório fica muito pesado; use outro sítio para backups)
safe_backups/
